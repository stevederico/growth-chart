# Required for auth
JWT_SECRET=
STRIPE_KEY=
STRIPE_ENDPOINT_SECRET=

# Comma-separated repos to track (owner/repo,owner/other). Seeds the repos
# table on first boot when it is empty. GITHUB_REPO (singular) is a fallback.
GITHUB_REPOS=
# Required for traffic (views/clones) endpoints. Create at github.com/settings/tokens
GITHUB_TOKEN=
